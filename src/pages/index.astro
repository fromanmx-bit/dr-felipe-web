---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import InicioSection from '../components/sections/InicioSection.astro';
import SobreElDrSection from '../components/sections/SobreElDrSection.astro';
import PediatriaNeonatologiaSection from '../components/sections/PediatriaNeonatologiaSection.astro';
import FormacionTrayectoriaSection from '../components/sections/FormacionTrayectoriaSection.astro';
import ConsultorioContactoSection from '../components/sections/ConsultorioContactoSection.astro';
import UbicacionSection from '../components/sections/UbicacionSection.astro';
---

<Layout
  title="Dr. Felipe Hernández Serna | Pediatría y Neonatología en Saltillo"
  description="Dr. Felipe Hernández Serna, médico especialista en Pediatría y Neonatología en Saltillo, Coahuila."
>
  <Header />
  <main>
    <InicioSection />
    <SobreElDrSection />
    <PediatriaNeonatologiaSection />
    <FormacionTrayectoriaSection />
    <ConsultorioContactoSection />
    <UbicacionSection />
  </main>
  <Footer />
</Layout>

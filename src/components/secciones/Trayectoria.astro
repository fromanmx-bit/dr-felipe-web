---
const hitos = [
  {
    categoria: 'Formación',
    texto: 'Médico Cirujano — Universidad Nacional Autónoma de México (UNAM).',
  },
  {
    categoria: 'Formación',
    texto: 'Especialidad en Pediatría — Hospital Pediátrico Tacubaya–UNAM.',
  },
  {
    categoria: 'Formación',
    texto: 'Especialidad en Neonatología — Hospital de la Mujer–UNAM.',
  },
  {
    categoria: 'Formación',
    texto: 'Certificación en Pediatría y certificación en Neonatología.',
  },
  {
    categoria: 'Trayectoria clínica',
    texto: 'Experiencia hospitalaria en Monterrey y Saltillo, incluyendo Doctors Hospital Monterrey y Hospital ISSSTE Saltillo.',
  },
  {
    categoria: 'Trayectoria clínica',
    texto: 'Jefatura de Servicio.',
  },
  {
    categoria: 'Docencia',
    texto: 'Profesor titular de Pediatría y catedrático asociado.',
  },
  {
    categoria: 'Docencia',
    texto: 'Participación como ponente en congresos nacionales e internacionales.',
  },
];

const claseCategoria: Record<string, string> = {
  'Formación': 'linea-tiempo__insignia--formacion',
  'Trayectoria clínica': 'linea-tiempo__insignia--clinica',
  'Docencia': 'linea-tiempo__insignia--docencia',
};
---

<section id="trayectoria" class="seccion seccion--cremosa" aria-label="Formación y trayectoria">
  <div class="contenedor">
    <div class="encabezado-seccion encabezado-seccion--centrado">
      <p class="etiqueta-superior">Formación y trayectoria</p>
      <h2>Una preparación construida paso a paso</h2>
    </div>

    <ol class="linea-tiempo">
      {hitos.map((hito) => (
        <li class="linea-tiempo__item">
          <span class="linea-tiempo__marcador" aria-hidden="true"></span>
          <div class="linea-tiempo__contenido">
            <span class={`insignia linea-tiempo__insignia ${claseCategoria[hito.categoria]}`}>
              {hito.categoria}
            </span>
            <p>{hito.texto}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .linea-tiempo {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: var(--ancho-lectura);
    margin-inline: auto;
    position: relative;
  }

  .linea-tiempo::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 6px;
    bottom: 6px;
    width: 1.5px;
    background: linear-gradient(180deg, var(--color-turquesa-linea), var(--color-borde-oscuro));
  }

  .linea-tiempo__item {
    position: relative;
    padding-left: 2.25rem;
    margin: 0 0 var(--e-lg);
  }

  .linea-tiempo__item:last-child {
    margin-bottom: 0;
  }

  .linea-tiempo__marcador {
    position: absolute;
    left: 0;
    top: 0.35em;
    width: 11px;
    height: 14px;
    border-radius: 60% 60% 50% 50%;
    background: var(--color-turquesa);
    box-shadow: 0 0 0 4px var(--color-crema);
  }

  .linea-tiempo__contenido p {
    margin: 0.4rem 0 0;
    color: var(--color-texto);
  }

  .linea-tiempo__insignia--formacion {
    background-color: var(--color-turquesa-suave);
    color: var(--color-azul-tinta);
  }

  .linea-tiempo__insignia--clinica {
    background-color: rgba(11, 43, 70, 0.08);
    color: var(--color-azul-profundo);
  }

  .linea-tiempo__insignia--docencia {
    background-color: var(--color-dorado-suave);
    color: #6b5326;
  }
</style>

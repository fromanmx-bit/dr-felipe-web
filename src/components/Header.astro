---
const enlaces = [
  { href: '#inicio', texto: 'Inicio' },
  { href: '#sobre-el-doctor', texto: 'Sobre el Dr.' },
  { href: '#pediatria-neonatologia', texto: 'Pediatría y Neonatología' },
  { href: '#formacion-trayectoria', texto: 'Formación y trayectoria' },
  { href: '#consultorio-contacto', texto: 'Consultorio y contacto' },
  { href: '#ubicacion', texto: 'Ubicación' },
];
---

<header class="encabezado">
  <div class="contenedor encabezado__interior">
    <a class="encabezado__logo" href="#inicio">
      <span class="visualmente-oculto">Dr. Felipe Hernández Serna</span>
      <span class="encabezado__logo-marcador" aria-hidden="true">Logotipo</span>
    </a>

    <button class="encabezado__boton-menu" aria-expanded="false" aria-controls="nav-principal" id="boton-menu">
      Menú
    </button>

    <nav class="encabezado__nav" id="nav-principal">
      <ul>
        {enlaces.map((enlace) => (
          <li><a href={enlace.href}>{enlace.texto}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .encabezado {
    position: sticky;
    top: 0;
    z-index: 10;
    background-color: var(--blanco);
    border-bottom: 1px solid var(--gris-neutro);
  }

  .encabezado__interior {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--espacio-sm);
    padding-bottom: var(--espacio-sm);
  }

  .encabezado__logo {
    display: inline-flex;
    text-decoration: none;
    flex-shrink: 0;
  }

  .encabezado__logo-marcador {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 120px;
    aspect-ratio: 3 / 1;
    border: 1px dashed rgba(11, 46, 79, 0.3);
    border-radius: 6px;
    background-color: rgba(47, 169, 161, 0.05);
    color: var(--azul-profundo);
    font-size: 0.7rem;
    letter-spacing: 0.03em;
    opacity: 0.65;
  }

  @media (min-width: 769px) {
    .encabezado__logo-marcador {
      width: 180px;
    }
  }

  .encabezado__boton-menu {
    display: none;
    background: none;
    border: 1px solid var(--azul-profundo);
    color: var(--azul-profundo);
    border-radius: 4px;
    padding: 0.4rem 0.75rem;
    font-family: var(--fuente-base);
  }

  .encabezado__nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--espacio-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .encabezado__nav a {
    color: var(--gris-texto);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .encabezado__nav a:hover {
    color: var(--turquesa);
  }

  @media (max-width: 768px) {
    .encabezado__boton-menu {
      display: inline-block;
    }

    .encabezado__nav {
      display: none;
      width: 100%;
    }

    .encabezado__nav.abierto {
      display: block;
    }

    .encabezado__nav ul {
      flex-direction: column;
      gap: var(--espacio-sm);
      padding: var(--espacio-md) 0;
    }

    .encabezado__interior {
      flex-wrap: wrap;
    }
  }
</style>

<script>
  const boton = document.getElementById('boton-menu');
  const nav = document.getElementById('nav-principal');

  boton?.addEventListener('click', () => {
    const abierto = nav?.classList.toggle('abierto');
    boton.setAttribute('aria-expanded', abierto ? 'true' : 'false');
  });
</script>

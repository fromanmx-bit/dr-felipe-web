---
import MarcoImagen from './ui/MarcoImagen.astro';
import Icono from './ui/Icono.astro';

const enlaces = [
  { href: '#inicio', texto: 'Inicio' },
  { href: '#el-doctor', texto: 'El Dr. Felipe' },
  { href: '#especialidades', texto: 'Especialidades' },
  { href: '#trayectoria', texto: 'Trayectoria' },
  { href: '#recursos', texto: 'Recursos' },
  { href: '#preguntas-frecuentes', texto: 'Preguntas' },
  { href: '#tramites', texto: 'Trámites' },
  { href: '#contacto', texto: 'Contacto' },
];
---

<header class="encabezado">
  <div class="contenedor encabezado__interior">
    <a class="encabezado__logo" href="#inicio">
      <span class="visualmente-oculto">Dr. Felipe Hernández Serna — inicio</span>
      <MarcoImagen
        variante="logotipo"
        ratio="3 / 1"
        etiqueta="Logotipo"
        anchoMaximo="128px"
        conMarco={false}
      />
    </a>

    <a class="encabezado__whatsapp-movil" href="https://wa.me/525563176446" target="_blank" rel="noopener noreferrer" aria-label="Escribir por WhatsApp">
      <Icono nombre="whatsapp" clase="encabezado__icono" />
    </a>

    <button class="encabezado__boton-menu" aria-expanded="false" aria-controls="nav-principal" id="boton-menu">
      <span class="visualmente-oculto">Abrir menú de navegación</span>
      <span class="encabezado__icono-menu" aria-hidden="true"></span>
    </button>

    <nav class="encabezado__nav" id="nav-principal" aria-label="Navegación principal">
      <ul>
        {enlaces.map((enlace) => (
          <li><a href={enlace.href}>{enlace.texto}</a></li>
        ))}
      </ul>
      <a class="boton boton--primario encabezado__cta" href="https://wa.me/525563176446" target="_blank" rel="noopener noreferrer">
        Agendar por WhatsApp
      </a>
    </nav>
  </div>
</header>

<style>
  .encabezado {
    position: sticky;
    top: 0;
    z-index: 40;
    background-color: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(6px);
    border-bottom: 1px solid var(--color-borde);
  }

  .encabezado__interior {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--e-sm);
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
  }

  .encabezado__logo {
    display: inline-flex;
    text-decoration: none;
    flex-shrink: 0;
  }

  .encabezado__whatsapp-movil {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    background-color: var(--color-turquesa-suave);
    color: var(--color-turquesa);
    margin-left: auto;
  }

  .encabezado__icono {
    width: 22px;
    height: 22px;
  }

  .encabezado__boton-menu {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: none;
    border: 1px solid var(--color-borde-oscuro);
    border-radius: var(--radio-sm);
    margin-left: 0.5rem;
  }

  .encabezado__icono-menu,
  .encabezado__icono-menu::before,
  .encabezado__icono-menu::after {
    display: block;
    width: 18px;
    height: 2px;
    background-color: var(--color-azul-profundo);
    position: relative;
    transition: transform var(--duracion) ease, opacity var(--duracion) ease;
  }

  .encabezado__icono-menu::before,
  .encabezado__icono-menu::after {
    content: '';
    position: absolute;
    left: 0;
  }

  .encabezado__icono-menu::before {
    top: -6px;
  }

  .encabezado__icono-menu::after {
    top: 6px;
  }

  .encabezado__boton-menu[aria-expanded='true'] .encabezado__icono-menu {
    background-color: transparent;
  }

  .encabezado__boton-menu[aria-expanded='true'] .encabezado__icono-menu::before {
    transform: translateY(6px) rotate(45deg);
  }

  .encabezado__boton-menu[aria-expanded='true'] .encabezado__icono-menu::after {
    transform: translateY(-6px) rotate(-45deg);
  }

  .encabezado__nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--e-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .encabezado__nav a {
    color: var(--color-texto);
    text-decoration: none;
    font-size: 0.92rem;
    font-weight: 500;
  }

  .encabezado__nav a:hover {
    color: var(--color-turquesa-texto);
  }

  .encabezado__cta {
    display: none;
  }

  @media (max-width: 899px) {
    .encabezado__nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background-color: var(--color-blanco);
      border-bottom: 1px solid var(--color-borde);
      box-shadow: var(--sombra-suave);
    }

    .encabezado__nav.abierto {
      display: block;
    }

    .encabezado__nav ul {
      flex-direction: column;
      gap: 0;
      padding: var(--e-sm) 0;
    }

    .encabezado__nav li a {
      display: block;
      padding: 0.85rem var(--e-md);
      min-height: 44px;
    }

    .encabezado__nav li + li a {
      border-top: 1px solid var(--color-borde);
    }

    .encabezado__cta {
      display: flex;
      margin: var(--e-sm) var(--e-md) var(--e-md);
    }
  }

  @media (min-width: 900px) {
    .encabezado__whatsapp-movil {
      display: none;
    }

    .encabezado__boton-menu {
      display: none;
    }

    .encabezado__nav {
      display: flex;
      align-items: center;
      gap: var(--e-lg);
    }

    .encabezado__cta {
      display: inline-flex;
      padding: 0.6rem 1.15rem;
      min-height: auto;
      font-size: 0.88rem;
    }
  }
</style>

<script>
  const boton = document.getElementById('boton-menu');
  const nav = document.getElementById('nav-principal');

  boton?.addEventListener('click', () => {
    const abierto = nav?.classList.toggle('abierto');
    boton.setAttribute('aria-expanded', abierto ? 'true' : 'false');
  });

  nav?.addEventListener('click', (evento) => {
    if ((evento.target as HTMLElement).tagName === 'A') {
      nav.classList.remove('abierto');
      boton?.setAttribute('aria-expanded', 'false');
    }
  });
</script>

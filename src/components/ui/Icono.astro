---
interface Props {
  nombre:
    | 'whatsapp'
    | 'calendario'
    | 'ubicacion'
    | 'correo'
    | 'documento'
    | 'factura'
    | 'chevron'
    | 'reloj'
    | 'hoja';
  clase?: string;
}

const { nombre, clase = '' } = Astro.props;
---

{
  nombre === 'whatsapp' && (
    <svg class={clase} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <path d="M7 17.5 4.5 20l1-3.6A7.5 7.5 0 1 1 9.6 19l-2.6-1.5Z" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M9 10.2c0 3 2.6 5.4 5.6 5.4.5 0 .7-.2.6-.6l-.3-1.2c-.1-.3-.4-.5-.7-.4l-1 .3c-.9-.5-1.9-1.5-2.4-2.4l.3-1c.1-.3 0-.6-.3-.7L9.6 9.3c-.4-.1-.6.1-.6.6v.3Z" />
    </svg>
  )
}

{
  nombre === 'calendario' && (
    <svg class={clase} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <rect x="4" y="5.5" width="16" height="14" rx="2" />
      <path d="M4 9.5h16M8 3.5v3M16 3.5v3" stroke-linecap="round" />
    </svg>
  )
}

{
  nombre === 'ubicacion' && (
    <svg class={clase} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <path d="M12 21s-6.5-5.6-6.5-11A6.5 6.5 0 0 1 18.5 10c0 5.4-6.5 11-6.5 11Z" stroke-linejoin="round" />
      <circle cx="12" cy="10" r="2.3" />
    </svg>
  )
}

{
  nombre === 'correo' && (
    <svg class={clase} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <rect x="3.5" y="5.5" width="17" height="13" rx="2" />
      <path d="m4.5 7 7.5 6 7.5-6" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}

{
  nombre === 'documento' && (
    <svg class={clase} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <path d="M7 3.5h7l4 4v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1v-16a1 1 0 0 1 1-1Z" stroke-linejoin="round" />
      <path d="M14 3.5v4h4M9 13h6M9 16.5h6" stroke-linecap="round" />
    </svg>
  )
}

{
  nombre === 'factura' && (
    <svg class={clase} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <path d="M6 3.5h12v17l-2.2-1.4L13.6 20l-1.6-1.4L10.4 20l-2.2-1.4L6 20.5Z" stroke-linejoin="round" />
      <path d="M9 8h6M9 11.5h6M9 15h3.5" stroke-linecap="round" />
    </svg>
  )
}

{
  nombre === 'chevron' && (
    <svg class={clase} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path d="m7 9.5 5 5 5-5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}

{
  nombre === 'reloj' && (
    <svg class={clase} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <circle cx="12" cy="12.5" r="8" />
      <path d="M12 8v4.5l3 2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}

{
  nombre === 'hoja' && (
    <svg class={clase} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
      <path d="M5 19c7-1 12-6 13-13-7 1-12 6-13 13Z" stroke-linejoin="round" />
      <path d="M6.5 17.5 15 9" stroke-linecap="round" />
    </svg>
  )
}

---
interface Props {
  clase?: string;
}

const { clase = '' } = Astro.props;
---

<svg
  class={`motivo-rama ${clase}`}
  viewBox="0 0 160 24"
  fill="none"
  stroke="currentColor"
  aria-hidden="true"
  focusable="false"
>
  <path d="M2 12h60" stroke-width="1.4" stroke-linecap="round" />
  <path d="M62 12c8-6 14-6 18 0s10 6 18 0" stroke-width="1.4" stroke-linecap="round" />
  <circle cx="80" cy="12" r="2.6" fill="currentColor" stroke="none" />
  <path d="M98 12h60" stroke-width="1.4" stroke-linecap="round" />
</svg>

<style>
  .motivo-rama {
    width: 140px;
    height: 20px;
    color: var(--color-dorado);
    opacity: 0.7;
  }
</style>

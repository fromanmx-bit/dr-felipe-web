---
import Icono from './Icono.astro';

interface Props {
  variante?: 'retrato' | 'logotipo' | 'simbolo' | 'editorial' | 'consultorio';
  ratio?: string;
  etiqueta: string;
  notaDesarrollo?: string;
  anchoMaximo?: string;
  conMarco?: boolean;
}

const {
  variante = 'editorial',
  ratio = '4 / 5',
  etiqueta,
  notaDesarrollo = 'Espacio reservado para imagen real',
  anchoMaximo,
  conMarco = true,
} = Astro.props;
---

<figure
  class={`marco-imagen marco-imagen--${variante} ${conMarco ? 'marco-imagen--decorado' : ''}`}
  style={anchoMaximo ? `--marco-ancho-maximo: ${anchoMaximo};` : undefined}
>
  <div class="marco-imagen__panel" style={`aspect-ratio: ${ratio};`}>
    <Icono nombre="hoja" clase="marco-imagen__icono" />
    <figcaption class="marco-imagen__etiqueta">{etiqueta}</figcaption>
    <p class="marco-imagen__nota">{notaDesarrollo}</p>
  </div>
</figure>

<style>
  .marco-imagen {
    margin: 0;
    width: 100%;
    max-width: var(--marco-ancho-maximo, none);
    position: relative;
  }

  .marco-imagen--decorado::before {
    content: '';
    position: absolute;
    inset: 14px -14px -14px 14px;
    border: 1.5px solid var(--color-dorado-suave);
    border-radius: var(--radio-lg);
    z-index: 0;
  }

  .marco-imagen__panel {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--e-xs);
    text-align: center;
    padding: var(--e-md);
    border-radius: var(--radio-lg);
    border: 1px solid var(--color-borde-oscuro);
    background: linear-gradient(160deg, var(--color-turquesa-suave) 0%, var(--color-blanco) 65%);
    box-shadow: var(--sombra-suave);
  }

  .marco-imagen__icono {
    width: 30px;
    height: 30px;
    color: var(--color-turquesa);
    opacity: 0.55;
  }

  .marco-imagen__etiqueta {
    font-family: var(--fuente-editorial);
    font-style: italic;
    color: var(--color-azul-profundo);
    font-size: 1rem;
    max-width: 22rem;
  }

  .marco-imagen__nota {
    margin: 0;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-texto-suave);
    opacity: 0.75;
  }

  .marco-imagen--logotipo .marco-imagen__panel {
    border-radius: var(--radio-sm);
    padding: 0.5rem 1rem;
    background: var(--color-blanco);
    box-shadow: none;
    border-color: var(--color-borde);
  }

  .marco-imagen--logotipo.marco-imagen--decorado::before {
    display: none;
  }

  .marco-imagen--logotipo .marco-imagen__icono {
    width: 18px;
    height: 18px;
  }

  .marco-imagen--logotipo .marco-imagen__etiqueta {
    font-size: 0.75rem;
    font-style: normal;
    font-family: var(--fuente-base);
    font-weight: 600;
    letter-spacing: 0.03em;
  }

  .marco-imagen--logotipo .marco-imagen__nota {
    display: none;
  }

  .marco-imagen--simbolo .marco-imagen__panel {
    background: linear-gradient(160deg, var(--color-crema-fuerte) 0%, var(--color-blanco) 70%);
  }

  .marco-imagen--simbolo .marco-imagen__icono {
    color: var(--color-dorado);
    width: 38px;
    height: 38px;
  }

  .marco-imagen--consultorio .marco-imagen__panel {
    background: linear-gradient(160deg, var(--color-crema) 0%, var(--color-blanco) 70%);
  }
</style>
